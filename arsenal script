-- ══════════════════════════════════════════════════════════════
--  SECTION 13.5: TELEPORT KILL v6.0 (BACKSTAB)
--  Arsenal-aware: spawn protection, anti-stuck, camera follow,
--  ground validation, instant bug recovery
-- ══════════════════════════════════════════════════════════════

local TeleportKill = {
    Enabled = false,
    IntervalMs = 50,
    Distance = 5,
    Target = nil,
    DelayMs = 500,
    LastTargetDied = 0,
    RandomOffset = Vector3.new(0, 0, 1),
    -- v6.0: Anti-stuck system
    StuckCount = 0,
    StuckThreshold = 5,       -- How many stuck frames before switching
    LastTeleportPos = nil,
    LastTeleportTime = 0,
    StuckCheckInterval = 0.3, -- Check stuck every 0.3s
    -- v6.0: Min height filter
    MinTargetHeight = -50,    -- Don't track targets below this Y
    -- v6.0: Camera follow
    CameraFollow = true,
    -- v6.0: Last update time for interval throttle
    LastUpdateTime = 0,
    -- v6.0: Consecutive fail counter for instant switch
    ConsecutiveFails = 0,
    MaxConsecutiveFails = 10,
}

local function UpdateTeleportKill()
    if not TeleportKill.Enabled then
        TeleportKill.Target = nil
        TeleportKill.StuckCount = 0
        TeleportKill.ConsecutiveFails = 0
        return
    end

    -- v6.0: Throttle by interval
    local now = tick()
    if (now - TeleportKill.LastUpdateTime) < (TeleportKill.IntervalMs / 1000) then
        return
    end
    TeleportKill.LastUpdateTime = now

    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    -- v6.0: Enhanced target validation for Arsenal
    local function IsValidForTeleport(p)
        -- Use strict on-map check
        if not IsAliveOnMap(p) then return false end
        if Aimbot.TeamCheck and not GameMode:IsEnemy(p) then return false end
        local char = p.Character
        local eRoot = char and char:FindFirstChild("HumanoidRootPart")
        if not eRoot then return false end

        -- v6.0: Reject targets below minimum map height
        -- (Arsenal spawn protection spawns real characters underground)
        if eRoot.Position.Y < TeleportKill.MinTargetHeight then return false end

        -- v6.0: Reject targets in void
        if eRoot.Position.Y < (Workspace.FallenPartsDestroyHeight + 20) then return false end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return false end
        if hum:GetState() == Enum.HumanoidStateType.Dead then return false end

        -- v6.0: Reject targets with spawn protection (ForceField)
        if char:FindFirstChildOfClass("ForceField") then return false end

        -- v6.0: Max teleport range
        if (eRoot.Position - myRoot.Position).Magnitude > 4000 then return false end

        return true
    end

    -- v6.0: Validate current target with strict checks
    if TeleportKill.Target then
        if not IsValidForTeleport(TeleportKill.Target) then
            TeleportKill.Target = nil
            TeleportKill.LastTargetDied = now
            TeleportKill.StuckCount = 0
            TeleportKill.ConsecutiveFails = 0
        end
    end

    -- v6.0: Anti-stuck detection — if we haven't moved for too long, switch target
    if TeleportKill.Target and TeleportKill.LastTeleportPos then
        if (now - TeleportKill.LastTeleportTime) > TeleportKill.StuckCheckInterval then
            local moved = (myRoot.Position - TeleportKill.LastTeleportPos).Magnitude
            if moved < 1.5 then
                TeleportKill.StuckCount = TeleportKill.StuckCount + 1
                if TeleportKill.StuckCount >= TeleportKill.StuckThreshold then
                    -- v6.0: We're stuck! Force switch to different target
                    local stuckTarget = TeleportKill.Target
                    TeleportKill.Target = nil
                    TeleportKill.StuckCount = 0
                    TeleportKill.LastTeleportTime = now

                    -- Find a different target
                    local bestTarget = nil
                    local bestDist = math.huge
                    for _, player in ipairs(Players:GetPlayers()) do
                        if player == LocalPlayer or player == stuckTarget then continue end
                        if IsValidForTeleport(player) then
                            local enemyRoot = player.Character:FindFirstChild("HumanoidRootPart")
                            local dist = (enemyRoot.Position - myRoot.Position).Magnitude
                            if dist < bestDist then
                                bestDist = dist
                                bestTarget = player
                            end
                        end
                    end
                    if bestTarget then
                        TeleportKill.Target = bestTarget
                    end
                    return
                end
            else
                TeleportKill.StuckCount = 0
            end
            TeleportKill.LastTeleportPos = myRoot.Position
            TeleportKill.LastTeleportTime = now
        end
    end

    -- Acquire new target
    if not TeleportKill.Target then
        if now - TeleportKill.LastTargetDied < (TeleportKill.DelayMs / 1000) then
            return
        end

        local bestTarget = nil
        local bestDist = math.huge

        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if IsValidForTeleport(player) then
                local enemyRoot = player.Character:FindFirstChild("HumanoidRootPart")
                local dist = (enemyRoot.Position - myRoot.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    bestTarget = player
                end
            end
        end

        if bestTarget then
            TeleportKill.Target = bestTarget
            TeleportKill.StuckCount = 0
            TeleportKill.ConsecutiveFails = 0
            TeleportKill.LastTeleportPos = myRoot.Position
            TeleportKill.LastTeleportTime = now
            local choices = {
                Vector3.new(0, 0, 1),     -- Behind
                Vector3.new(1, 0, 0),     -- Right
                Vector3.new(-1, 0, 0),    -- Left
                Vector3.new(0, 1.5, 0.5)  -- Above/Behind
            }
            TeleportKill.RandomOffset = choices[math.random(1, #choices)]
        end
    end

    -- Execute teleport
    if TeleportKill.Target then
        local targetChar = TeleportKill.Target.Character
        if not targetChar then
            TeleportKill.ConsecutiveFails = TeleportKill.ConsecutiveFails + 1
            if TeleportKill.ConsecutiveFails >= TeleportKill.MaxConsecutiveFails then
                TeleportKill.Target = nil
                TeleportKill.ConsecutiveFails = 0
            end
            return
        end

        local enemyRoot = targetChar:FindFirstChild("HumanoidRootPart")
        if not enemyRoot then
            TeleportKill.ConsecutiveFails = TeleportKill.ConsecutiveFails + 1
            if TeleportKill.ConsecutiveFails >= TeleportKill.MaxConsecutiveFails then
                TeleportKill.Target = nil
                TeleportKill.ConsecutiveFails = 0
            end
            return
        end

        -- v6.0: Double-check target is still valid right before teleport
        if enemyRoot.Position.Y < TeleportKill.MinTargetHeight then
            TeleportKill.Target = nil
            return
        end

        TeleportKill.ConsecutiveFails = 0

        local lookVec = enemyRoot.CFrame.LookVector
        local rightVec = enemyRoot.CFrame.RightVector

        local flatLook = Vector3.new(lookVec.X, 0, lookVec.Z)
        if flatLook.Magnitude > 0.001 then
            flatLook = flatLook.Unit
        else
            flatLook = Vector3.new(0, 0, -1)
        end

        local flatRight = Vector3.new(rightVec.X, 0, rightVec.Z)
        if flatRight.Magnitude > 0.001 then
            flatRight = flatRight.Unit
        else
            flatRight = Vector3.new(1, 0, 0)
        end

        local offsetDir = (-flatLook * TeleportKill.RandomOffset.Z)
            + (flatRight * TeleportKill.RandomOffset.X)
            + (Vector3.new(0, 1, 0) * TeleportKill.RandomOffset.Y)

        local targetPos = enemyRoot.Position + (offsetDir * TeleportKill.Distance)

        -- Raycast to avoid teleporting into walls
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances = {myChar, targetChar}

        local rayResult = Workspace:Raycast(
            enemyRoot.Position,
            offsetDir * TeleportKill.Distance,
            rayParams
        )

        local backPos = targetPos
        if rayResult then
            backPos = rayResult.Position - (offsetDir.Unit * 1)
        end

        -- v6.0: Ensure teleport position is not underground
        -- Raycast downward to find ground
        local groundCheck = Workspace:Raycast(
            backPos + Vector3.new(0, 5, 0),
            Vector3.new(0, -50, 0),
            rayParams
        )
        if groundCheck then
            -- Place slightly above ground
            if backPos.Y < groundCheck.Position.Y + 2 then
                backPos = Vector3.new(backPos.X, groundCheck.Position.Y + 2.5, backPos.Z)
            end
        end

        -- Teleport character facing the enemy
        myRoot.CFrame = CFrame.lookAt(backPos, enemyRoot.Position)
        myRoot.AssemblyLinearVelocity = Vector3.zero
        myRoot.AssemblyAngularVelocity = Vector3.zero

        -- v6.0: Camera follow — set camera behind our character looking at enemy
        if TeleportKill.CameraFollow and Camera then
            local camOffset = myRoot.CFrame.LookVector * -4 + Vector3.new(0, 2.5, 0)
            Camera.CFrame = CFrame.lookAt(myRoot.Position + camOffset, enemyRoot.Position)
        end

        -- Update stuck tracking
        TeleportKill.LastTeleportPos = myRoot.Position
        TeleportKill.LastTeleportTime = now
    end
end

