--  SECTION 6: SMART GAME MODE & TEAM DETECTION (v6.0)
--  Instant first-frame detection, comprehensive FFA heuristic,
--  handles all Arsenal modes including FFA/Teams/Mixed
-- ══════════════════════════════════════════════════════════════

local GameMode = {
    IsFFA            = false,
    LastCheck        = -math.huge, -- v6.0: Force instant detection on first call
    CheckInterval    = 0.05,
    _initialized     = false,
    _teamHooksDone   = false,
    _cachedTeamCount = 0,
}

function GameMode:DetectMode()
    local now = tick()
    if now - self.LastCheck < self.CheckInterval and self._initialized then return end
    self.LastCheck = now
    self._initialized = true

    local teams = TeamsService:GetTeams()
    if #teams == 0 then
        self.IsFFA = true
        self._cachedTeamCount = 0
        return
    end

    local teamCounts = {}
    local withTeam, withoutTeam, total = 0, 0, 0
    local singleTeamAll = true
    local firstTeam = nil

    for _, player in ipairs(Players:GetPlayers()) do
        total = total + 1
        if player.Team then
            teamCounts[player.Team] = (teamCounts[player.Team] or 0) + 1
            withTeam = withTeam + 1
            if not firstTeam then
                firstTeam = player.Team
            elseif player.Team ~= firstTeam then
                singleTeamAll = false
            end
        else
            withoutTeam = withoutTeam + 1
            singleTeamAll = false
        end
    end

    local distinctTeams = 0
    for _, count in pairs(teamCounts) do
        if count > 0 then distinctTeams = distinctTeams + 1 end
    end
    self._cachedTeamCount = distinctTeams

    -- v6.0: Enhanced FFA detection heuristic
    -- FFA conditions:
    -- 1. No teams exist at all
    -- 2. Only one distinct team (everyone on same team = FFA-like)
    -- 3. More players without teams than with teams
    -- 4. Too few players to determine (< 2)
    -- 5. All players are on the same single team
    -- 6. Arsenal-specific: if "FFA" is in any team name
    local hasFFATeamName = false
    for _, team in ipairs(teams) do
        if string.find(string.lower(team.Name), "ffa") then
            hasFFATeamName = true
            break
        end
    end

    self.IsFFA = (distinctTeams <= 1)
        or (withoutTeam > withTeam)
        or (total < 2)
        or singleTeamAll
        or hasFFATeamName

    -- v6.0: Hook team changes for all players (once)
    if not self._teamHooksDone then
        self._teamHooksDone = true
        for _, player in ipairs(Players:GetPlayers()) do
            self:_hookTeamChange(player)
        end
    end
end

function GameMode:_hookTeamChange(player)
    local key = "TeamProp_" .. player.UserId
    if Connections[key] then return end
    TrackConnection(key, player:GetPropertyChangedSignal("Team"):Connect(function()
        self.LastCheck = -math.huge -- Force re-detect immediately
    end))
end

function GameMode:ForceDetect()
    self.LastCheck = -math.huge
    self:DetectMode()
end

function GameMode:IsEnemy(player)
    self:DetectMode()
    if self.IsFFA then return true end
    if not LocalPlayer.Team then return true end
    if not player.Team then
        -- v6.0: In team mode, player without team could be spectator or glitch
        -- Treat as non-enemy to avoid targeting spectators
        return false
    end
    if LocalPlayer.Team ~= player.Team then return true end
    if LocalPlayer.TeamColor ~= player.TeamColor then return true end
    return false
end

function GameMode:GetTeamDisplayColor(player)
    self:DetectMode()
    if self.IsFFA then
        return Color3.fromRGB(255, 85, 35)
    elseif self:IsEnemy(player) then
        return Color3.fromRGB(255, 40, 40)
    else
        return Color3.fromRGB(40, 180, 255)
    end
end

-- v6.0: Force immediate detection on script load
GameMode:ForceDetect()

