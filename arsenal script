local originalMaterials = {}
local originalShadows = game:GetService("Lighting").GlobalShadows

GraphicsTab:CreateToggle({
    Name = "Lowest Graphics Mode",
    CurrentValue = false,
    Flag = "LowGraphicsToggle",
    Callback = function(Value)
        local lighting = game:GetService("Lighting")
        if Value then
            lighting.GlobalShadows = false
            lighting.FogEnd = 9e9
            for _, desc in ipairs(Workspace:GetDescendants()) do
                if desc:IsA("BasePart") and desc.ClassName ~= "Terrain" then
                    originalMaterials[desc] = desc.Material
                    desc.Material = Enum.Material.SmoothPlastic
                end
            end
            for _, fx in ipairs(lighting:GetChildren()) do
                if fx:IsA("PostEffect") or fx:IsA("BloomEffect") or fx:IsA("BlurEffect")
                or fx:IsA("SunRaysEffect") or fx:IsA("DepthOfFieldEffect") then
                    fx.Enabled = false
                end
            end
        else
            lighting.GlobalShadows = originalShadows
            for part, mat in pairs(originalMaterials) do
                if part and part.Parent then part.Material = mat end
            end
            table.clear(originalMaterials)
            for _, fx in ipairs(lighting:GetChildren()) do
                if fx:IsA("PostEffect") or fx:IsA("BloomEffect") or fx:IsA("BlurEffect")
                or fx:IsA("SunRaysEffect") or fx:IsA("DepthOfFieldEffect") then
                    fx.Enabled = true
                end
            end
        end
    end,
})

GraphicsTab:CreateToggle({
    Name = "Night Mode (enable Fullbright after)",
    CurrentValue = false,
    Flag = "ForceNightTime",
    Callback = function(Value)
        KillConnection("NightLoop")
        local lighting = game:GetService("Lighting")
        if Value then
            lighting.ClockTime = 0
            lighting.Ambient = Color3.fromRGB(30, 30, 40)
            lighting.OutdoorAmbient = Color3.fromRGB(15, 15, 20)
            TrackConnection("NightLoop", RunService.Heartbeat:Connect(function()
                lighting.ClockTime = 0
            end))
        else
            lighting.ClockTime = 14
            lighting.Ambient = Color3.fromRGB(128, 128, 128)
            lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
        end
    end,
})

GraphicsTab:CreateToggle({
    Name = "Color Vibrance",
    CurrentValue = false,
    Flag = "VibranceMode",
    Callback = function(Value)
        local lighting = game:GetService("Lighting")
        if Value then
            local cc = lighting:FindFirstChild("VibranceColorCorrection")
                or Instance.new("ColorCorrectionEffect")
            cc.Name = "VibranceColorCorrection"
            cc.Saturation = 0.45
            cc.Contrast = 0.15
            cc.Brightness = 0.02
            cc.Parent = lighting
        else
            local cc = lighting:FindFirstChild("VibranceColorCorrection")
            if cc then cc:Destroy() end
        end
    end,
})

GraphicsTab:CreateToggle({
    Name = "Realistic Mode",
    CurrentValue = false,
    Flag = "RealisticMode",
    Callback = function(Value)
        local lighting = game:GetService("Lighting")
        if Value then
            lighting.Technology = Enum.Technology.Future
            lighting.GlobalShadows = true
            lighting.Brightness = 2.5
            lighting.EnvironmentSpecularScale = 1
            lighting.EnvironmentDiffuseScale = 1

            local cc = lighting:FindFirstChild("RealColor") or Instance.new("ColorCorrectionEffect")
            cc.Name = "RealColor"
            cc.Brightness = -0.02
            cc.Contrast = 0.18
            cc.Saturation = 0.08
            cc.TintColor = Color3.fromRGB(255, 250, 245)
            cc.Parent = lighting

            local bloom = lighting:FindFirstChild("RealBloom") or Instance.new("BloomEffect")
            bloom.Name = "RealBloom"
            bloom.Intensity = 0.35
            bloom.Size = 24
            bloom.Threshold = 0.9
            bloom.Parent = lighting

            local sun = lighting:FindFirstChild("RealSunRays") or Instance.new("SunRaysEffect")
            sun.Name = "RealSunRays"
            sun.Intensity = 0.25
            sun.Spread = 0.7
            sun.Parent = lighting

            local atm = lighting:FindFirstChild("RealAtmosphere") or Instance.new("Atmosphere")
            atm.Name = "RealAtmosphere"
            atm.Density = 0.3
            atm.Offset = 0.25
            atm.Glare = 1
            atm.Haze = 0.5
            atm.Parent = lighting
        else
            lighting.Technology = Enum.Technology.ShadowMap
            lighting.Brightness = 1
            lighting.EnvironmentSpecularScale = 0
            lighting.EnvironmentDiffuseScale = 0

            local names = {"RealColor", "RealBloom", "RealSunRays", "RealAtmosphere"}
            for _, name in ipairs(names) do
                local obj = lighting:FindFirstChild(name)
                if obj then obj:Destroy() end
            end
        end
    end,
})

