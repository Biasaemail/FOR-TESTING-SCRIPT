--  SECTION 7: OPTIMIZED VISIBILITY CHECK (v6.0)
--  Near-zero-latency filter rebuild, efficient multi-point,
--  priority-ordered check points for early exit
-- ══════════════════════════════════════════════════════════════

local VisibilityParams = RaycastParams.new()
VisibilityParams.FilterType = Enum.RaycastFilterType.Exclude
VisibilityParams.IgnoreWater = true

local _visFilterTime = 0
local _visFilterDirty = true

-- v6.0: Mark filter dirty when players join/leave/respawn
local function MarkVisFilterDirty()
    _visFilterDirty = true
end

local function RebuildVisibilityFilter()
    local now = tick()
    -- v6.0: Rebuild every frame if dirty, otherwise every 0.016s (60fps)
    if not _visFilterDirty and (now - _visFilterTime) < 0.016 then return end
    _visFilterTime = now
    _visFilterDirty = false

    local filter = {Camera}
    local localChar = LocalPlayer.Character
    if localChar then filter[#filter + 1] = localChar end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            filter[#filter + 1] = p.Character
        end
    end
    VisibilityParams.FilterDescendantsInstances = filter
end

-- v6.0: Priority-ordered multi-point check with early exit
-- Checks aim part first (most likely to be visible), then fallbacks
local function IsVisibleAdvanced(targetChar, targetPos)
    if not targetChar or not targetChar.Parent then return false end
    RebuildVisibilityFilter()
    local origin = Camera.CFrame.Position

    -- v6.0: Build check points in priority order (aim part first for early exit)
    local checkPoints = { targetPos }

    local head = targetChar:FindFirstChild("Head")
    if head and head.Position ~= targetPos then
        checkPoints[#checkPoints + 1] = head.Position
    end

    local torso = targetChar:FindFirstChild("UpperTorso") or targetChar:FindFirstChild("Torso")
    if torso and torso.Position ~= targetPos then
        checkPoints[#checkPoints + 1] = torso.Position
    end

    local hrp = targetChar:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Position ~= targetPos then
        checkPoints[#checkPoints + 1] = hrp.Position
    end

    -- v6.0: Add extremity points for better coverage
    local lArm = targetChar:FindFirstChild("LeftUpperArm") or targetChar:FindFirstChild("Left Arm")
    if lArm then checkPoints[#checkPoints + 1] = lArm.Position end
    local rArm = targetChar:FindFirstChild("RightUpperArm") or targetChar:FindFirstChild("Right Arm")
    if rArm then checkPoints[#checkPoints + 1] = rArm.Position end

    for _, point in ipairs(checkPoints) do
        local direction = point - origin
        local dist = direction.Magnitude
        if dist < 1 then return true end
        local result = Workspace:Raycast(origin, direction, VisibilityParams)
        if not result then
            return true -- Nothing hit = clear line of sight
        end
        if (origin - result.Position).Magnitude >= dist * 0.95 then
            return true -- Hit something very close to target = visible
        end
    end
    return false
end

-- ══════════════════════════════════════════════════════════════
--  SECTION 8: PREDICTION ENGINE v6.0
--  Weighted Linear Regression, enhanced confidence model,
--  super-accurate velocity tracking, improved strafe & jump arc
-- ══════════════════════════════════════════════════════════════

local PredictionData = {}
local ROBLOX_GRAVITY = 196.2

-- Configurable prediction parameters (exposed to UI)
local PredictionConfig = {
    VelocitySmoothing    = 15,
    AccelSmoothing       = 8,
    AccelCap             = 800,
    VelocityCap          = 600,
    LookAheadMultiplier  = 4,
    LookAheadMax         = 0.2,
    ManualPing           = 0,
    ConfidenceGainRate   = 6,    -- v6.0: Faster confidence build
    ConfidenceLossRate   = 4,    -- v6.0: Slower confidence loss (more stable)
    StrafeSensitivity    = 3,
    StrafeWindow         = 0.8,
    StrafeDampen         = 0.25,
    JumpArcEnabled       = true,
    JumpThreshold        = 12,
    DirectionReactFast   = 2.5,
    DirectionReactMed    = 1.6,
    EarlyBeta            = 0.85,
    EarlySamples         = 3,
    -- v6.0: New parameters
    HistorySamples       = 10,    -- More samples for regression (was 7)
    WeightedRegression   = true,  -- Use exponential weighting on samples
    WeightDecay          = 0.7,   -- Weight decay per sample (newer = heavier)
    PingSmoothing        = 0.3,   -- Smooth ping readings to avoid jitter
}

-- v6.0: Smoothed ping value to avoid jitter
local _smoothedPing = 0.05

local function GetSmoothedPing()
    local rawPing = 0
    if PredictionConfig.ManualPing > 0 then
        return PredictionConfig.ManualPing / 1000
    end
    pcall(function() rawPing = LocalPlayer:GetNetworkPing() end)
    if not rawPing or rawPing == 0 then
        pcall(function()
            local stats = game:GetService("Stats")
            local net = stats:FindFirstChild("Network")
            if net and net:FindFirstChild("ServerStatsItem") then
                rawPing = net.ServerStatsItem["Data Ping"]:GetValue() / 1000
            end
        end)
    end
    rawPing = math.clamp(rawPing or 0.05, 0.02, 0.2)
    _smoothedPing = _smoothedPing + (rawPing - _smoothedPing) * PredictionConfig.PingSmoothing
    return _smoothedPing
end

local function UpdatePrediction(player, worldPos, dt)
    dt = math.max(dt, 0.0001)
    local d = PredictionData[player]
    local cfg = PredictionConfig

    -- Teleport / Death Snap Reset (Anomaly Detector)
    if d and ((worldPos - d.lastPos).Magnitude > 40
        or worldPos.Y < Workspace.FallenPartsDestroyHeight + 50
        or d.character ~= player.Character) then
        d = nil
    end

    if not d then
        PredictionData[player] = {
            character = player.Character,
            lastPos = worldPos, velocity = Vector3.zero, acceleration = Vector3.zero,
            smoothVelocity = Vector3.zero, predictedPos = worldPos, prevVelocity = Vector3.zero,
            sampleCount = 0, confidence = 0,
            strafeHistory = {}, strafing = false, strafeCenter = worldPos,
            airborne = false, jumpTime = 0, jumpStartVel = Vector3.zero,
            posHistory = {},
        }
        return
    end

    -- v6.0: Enhanced position history with timestamps
    local now = tick()
    table.insert(d.posHistory, { pos = worldPos, time = now })
    while #d.posHistory > cfg.HistorySamples do table.remove(d.posHistory, 1) end

    -- v6.0: Weighted Linear Regression for velocity estimation
    -- Recent samples are weighted exponentially heavier for faster response
    local rawVelocity = Vector3.zero
    if #d.posHistory >= 3 then
        local n = #d.posHistory
        local firstTime = d.posHistory[1].time

        if cfg.WeightedRegression then
            -- Exponentially weighted least squares
            local sumW, sumWT, sumWT2 = 0, 0, 0
            local sumWP, sumWPT = Vector3.zero, Vector3.zero
            for i = 1, n do
                local t = d.posHistory[i].time - firstTime
                local p = d.posHistory[i].pos
                -- Weight: newer samples (higher i) get exponentially more weight
                local w = math.pow(cfg.WeightDecay, n - i) -- decay^(distance from newest)
                -- Invert: newest = decay^0 = 1, oldest = decay^(n-1)
                -- Actually we want newest=heaviest: w = (1/decay)^(n-i) or just reverse
                w = math.pow(1 / cfg.WeightDecay, i) -- Newer = heavier
                sumW = sumW + w
                sumWT = sumWT + w * t
                sumWT2 = sumWT2 + w * t * t
                sumWP = sumWP + p * w
                sumWPT = sumWPT + p * (w * t)
            end
            local denom = sumW * sumWT2 - sumWT * sumWT
            if denom > 0.0001 then
                rawVelocity = (sumW * sumWPT - sumWT * sumWP) / denom
            else
                rawVelocity = (worldPos - d.lastPos) / dt
            end
        else
            -- Standard unweighted linear regression
            local sumT, sumT2 = 0, 0
            local sumVec, sumVecT = Vector3.zero, Vector3.zero
            for i = 1, n do
                local t = d.posHistory[i].time - firstTime
                local p = d.posHistory[i].pos
                sumT = sumT + t
                sumT2 = sumT2 + (t * t)
                sumVec = sumVec + p
                sumVecT = sumVecT + p * t
            end
            local denom = n * sumT2 - (sumT * sumT)
            if denom > 0.0001 then
                rawVelocity = (n * sumVecT - sumT * sumVec) / denom
            else
                rawVelocity = (worldPos - d.lastPos) / dt
            end
        end
    else
        rawVelocity = (worldPos - d.lastPos) / dt
    end

    if cfg.VelocityCap > 0 and rawVelocity.Magnitude > cfg.VelocityCap then
        rawVelocity = rawVelocity.Unit * cfg.VelocityCap
    end

    -- v6.0: Enhanced Kalman confidence with prediction error tracking
    local predErr = (worldPos - d.predictedPos).Magnitude
    if predErr < 1.5 then
        -- Excellent prediction — build confidence fast
        d.confidence = math.min(d.confidence + dt * cfg.ConfidenceGainRate * 1.5, 1)
    elseif predErr < 4 then
        -- Good prediction — steady confidence
        d.confidence = math.min(d.confidence + dt * cfg.ConfidenceGainRate * 0.5, 1)
    elseif predErr < 8 then
        -- Okay prediction — slight decay
        d.confidence = math.clamp(d.confidence - dt * 1.0, 0.2, 1)
    else
        -- Poor prediction — decay
        d.confidence = math.max(d.confidence - dt * cfg.ConfidenceLossRate, 0.05)
    end

    -- Adaptive beta
    local baseBeta = math.clamp(1 - math.exp(-cfg.VelocitySmoothing * dt), 0.05, 0.9)
    local beta

    d.sampleCount = math.min(d.sampleCount + 1, 30)
    if d.sampleCount < cfg.EarlySamples then
        beta = cfg.EarlyBeta
    else
        beta = baseBeta * (1.2 - d.confidence * 0.6)
        beta = math.clamp(beta, 0.05, 0.95)
    end

    -- Direction change reaction
    if d.velocity.Magnitude > 2 and rawVelocity.Magnitude > 2 then
        local dot = d.velocity.Unit:Dot(rawVelocity.Unit)
        if dot < 0.1 then
            beta = math.clamp(beta * cfg.DirectionReactFast, 0.3, 0.95)
        elseif dot < 0.4 then
            beta = math.clamp(beta * cfg.DirectionReactMed, 0.15, 0.9)
        end
    end

    -- Update velocity
    d.prevVelocity = d.velocity
    d.velocity = d.velocity:Lerp(rawVelocity, beta)

    -- Update acceleration
    local rawAccel = (d.velocity - d.prevVelocity) / dt
    if rawAccel.Magnitude > cfg.AccelCap then rawAccel = rawAccel.Unit * cfg.AccelCap end
    local accelBeta = math.clamp(1 - math.exp(-cfg.AccelSmoothing * dt), 0.05, 0.6)
    d.acceleration = d.acceleration:Lerp(rawAccel, accelBeta)

    -- Smooth velocity for strafe
    local smoothBeta = math.clamp(1 - math.exp(-5 * dt), 0.02, 0.4)
    d.smoothVelocity = d.smoothVelocity:Lerp(d.velocity, smoothBeta)

    -- STRAFE DETECTION
    local hx = d.velocity.X
    local hz = d.velocity.Z
    -- v6.0: Use the larger lateral component for strafe detection
    local lateralMag = math.sqrt(hx * hx + hz * hz)
    local sign = 0
    if lateralMag > 1 then
        -- Use the dominant axis for sign detection
        if math.abs(hx) >= math.abs(hz) then
            sign = hx > 0 and 1 or -1
        else
            sign = hz > 0 and 1 or -1
        end
    end
    if sign ~= 0 then
        d.strafeHistory[#d.strafeHistory + 1] = { sign = sign, time = now }
    end
    while #d.strafeHistory > 0 and (now - d.strafeHistory[1].time) > cfg.StrafeWindow do
        table.remove(d.strafeHistory, 1)
    end
    local crossings = 0
    for i = 2, #d.strafeHistory do
        if d.strafeHistory[i].sign ~= d.strafeHistory[i - 1].sign then
            crossings = crossings + 1
        end
    end
    d.strafing = crossings >= cfg.StrafeSensitivity
    if d.strafing then
        d.strafeCenter = d.strafeCenter:Lerp(worldPos, math.clamp(dt * 5, 0.05, 0.3))
    end

    -- AIRBORNE DETECTION & SMART JUMP LOGIC
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local wasAir = d.airborne

    if hum then
        local state = hum:GetState()
        d.airborne = state == Enum.HumanoidStateType.Jumping
            or state == Enum.HumanoidStateType.Freefall
    else
        d.airborne = math.abs(d.velocity.Y) > cfg.JumpThreshold
    end

    if d.airborne and not wasAir then
        d.jumpTime = 0
        d.jumpStartVel = d.velocity -- v6.0: Capture initial jump velocity
    end
    if d.airborne then d.jumpTime = d.jumpTime + dt end

    d.lastPos = worldPos
end

local function PredictPosition(player, worldPos, dt)
    local d = PredictionData[player]
    if not d or d.sampleCount < 2 then return worldPos end
    local cfg = PredictionConfig

    -- v6.0: Use smoothed ping for stable prediction
    local ping = GetSmoothedPing()

    local lookAhead = math.clamp(
        dt * cfg.LookAheadMultiplier + (ping * 1.5),
        0,
        cfg.LookAheadMax
    )

    local dist = (Camera.CFrame.Position - worldPos).Magnitude

    -- v6.0: Smoother close-quarters scaling (cubic ease instead of linear)
    if dist < 45 then
        local t = math.clamp((dist - 8) / 37, 0, 1)
        lookAhead = lookAhead * (t * t * t) -- Cubic ease for smoother falloff
    end

    local predicted

    if d.strafing then
        -- v6.0: Better strafe center tracking — blend toward current pos
        local centerBlend = d.strafeCenter:Lerp(worldPos, 0.65)
        predicted = centerBlend + d.smoothVelocity * (lookAhead * cfg.StrafeDampen)
    elseif cfg.JumpArcEnabled and d.airborne and d.jumpTime < 2 then
        local t = lookAhead
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum and hum:GetState() == Enum.HumanoidStateType.Jumping then
            -- v6.0: Use captured jump start velocity for more stable arc
            local jumpVel = d.jumpStartVel.Magnitude > 1 and d.jumpStartVel or d.velocity
            predicted = worldPos + jumpVel * t
        else
            -- Freefall: apply gravity
            predicted = worldPos
                + d.velocity * t
                + Vector3.new(0, -ROBLOX_GRAVITY, 0) * (0.5 * t * t)
            -- v6.0: Smarter floor clamp — don't predict below ground
            if predicted.Y < worldPos.Y - 6 then
                predicted = Vector3.new(predicted.X, worldPos.Y - 6, predicted.Z)
            end
        end
    else
        -- Standard linear + acceleration prediction
        predicted = worldPos
            + d.velocity * lookAhead
            + d.acceleration * (0.5 * lookAhead * lookAhead)
    end

    -- v6.0: Adaptive prediction radius based on confidence and distance
    local baseRadius = math.clamp(dist * 0.35, 2, 18)
    local confidenceScale = math.clamp(d.confidence * 0.5 + 0.5, 0.5, 1) -- High confidence = allow larger radius
    local maxPredictionRadius = baseRadius * confidenceScale
    local pDist = (predicted - worldPos).Magnitude
    if pDist > maxPredictionRadius then
        predicted = worldPos + (predicted - worldPos).Unit * maxPredictionRadius
    end

    d.predictedPos = predicted

    -- v6.0: Higher confidence blend ceiling for accurate shots
    local blend = math.clamp(d.confidence * 0.8 + 0.15, 0.15, 0.95)
    return worldPos:Lerp(predicted, blend)
end

local function ClearPrediction(player) PredictionData[player] = nil end
local function ClearAllPredictions() table.clear(PredictionData) end

