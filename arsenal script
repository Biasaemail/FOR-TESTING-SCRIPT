function Aimbot:GetTargetInfo(player)
    if not IsAlive(player) then return nil end
    local char = player.Character
    local aimPart = GetBodyPart(char, self.AimPart)
    if not aimPart or not aimPart.Parent then return nil end
    local worldPos = aimPart.Position
    local screenPos3, onScreen = Camera:WorldToViewportPoint(worldPos)
    local screenPos = Vector2.new(screenPos3.X, screenPos3.Y)
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local dist3D = myRoot and (worldPos - myRoot.Position).Magnitude or math.huge
    local hum = char:FindFirstChildOfClass("Humanoid")
    return {
        player = player, character = char, name = player.DisplayName or player.Name,
        health = hum and hum.Health or 0, maxHealth = hum and hum.MaxHealth or 100,
        worldPos = worldPos, screenPos = screenPos, depth = screenPos3.Z,
        onScreen = onScreen, dist3D = dist3D
    }
end

function Aimbot:ScoreTarget(info, center)
    local sd = (info.screenPos - center).Magnitude
    if self.PriorityMode == "Lowest HP" then
        return info.health + sd * 0.1
    elseif self.PriorityMode == "Nearest" then
        return info.dist3D + sd * 0.3
    elseif self.PriorityMode == "Threat" then
        local score = sd * 0.5
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local eRoot = info.character and info.character:FindFirstChild("HumanoidRootPart")
        if myRoot and eRoot then
            local d2m = (myRoot.Position - eRoot.Position)
            if d2m.Magnitude > 1 then
                score = score - eRoot.CFrame.LookVector:Dot(d2m.Unit) * 120
            end
        end
        return score + (info.health / math.max(info.maxHealth, 1)) * 20
    else
        return sd + (info.health / math.max(info.maxHealth, 1)) * 30 + math.min(info.dist3D * 0.01, 20)
    end
end

function Aimbot:IsLockValid(dt)
    local p = self.LockedPlayer
    if not p or not p.Parent or not IsAlive(p) then return false end
    if self.TeamCheck and not GameMode:IsEnemy(p) then return false end
    if table.find(self.IgnoredNames, p.Name) then return false end

    local info = self:GetTargetInfo(p)
    if not info then return false end
    if info.dist3D > self.MaxDistance then return false end
    if self.MinDistance > 0 and info.dist3D < self.MinDistance then return false end

    -- User override breakout
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local sd = (info.screenPos - center).Magnitude

    if self._is3DLock and self.Smart3D and info.dist3D <= self.Smart3DRange then
        -- 3D mode: check mouse flick to cancel
        local mouseDelta = UserInputService:GetMouseDelta()
        if mouseDelta.Magnitude > 25 then
            return false
        end
    else
        if sd > self.CurrentFOVRadius * self.UnlockThreshold then
            return false
        end
    end

    -- Visibility with grace
    if self.VisCheck then
        if not IsVisibleAdvanced(info.character, info.worldPos) then
            self.OccludedTime = self.OccludedTime + dt
            self.LastTargetVisible = false
            if self.OccludedTime > self.GracePeriod then return false end
        else
            self.OccludedTime = 0
            self.LastTargetVisible = true
        end
    else
        self.LastTargetVisible = true
    end
    return true
end

function Aimbot:AcquireTarget()
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    if self.AutoSwitch and self.LastTargetScreenPos then
        center = self.LastTargetScreenPos
        self.LastTargetScreenPos = nil
    end

    local potentialTargets = {}
    local camPos = Camera.CFrame.Position
    local camLook = Camera.CFrame.LookVector
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not IsAlive(player) then continue end
        if self.TeamCheck and not GameMode:IsEnemy(player) then continue end
        if table.find(self.IgnoredNames, player.Name) then continue end
        local info = self:GetTargetInfo(player)
        if not info then continue end
        if info.dist3D > self.MaxDistance then continue end
        if self.MinDistance > 0 and info.dist3D < self.MinDistance then continue end

        local score = -math.huge
        local is3D = false

        if self.Smart3D and info.dist3D <= (self.Smart3DRange * 1.5) then
            -- ═══════════════════════════════════════════
            -- v6.0: ENHANCED 3D PRIORITY ENGINE
            -- Environment-aware scoring with multiple threat vectors
            -- ═══════════════════════════════════════════
            is3D = true
            local dirToTarget = (info.worldPos - camPos)
            local dirUnit = dirToTarget.Magnitude > 0.1 and dirToTarget.Unit or Vector3.zero
            local dot = camLook:Dot(dirUnit)

            -- Base score: strongly favor closer targets
            score = 20000 - info.dist3D * 20

            -- === THREAT VECTOR 1: Flank/Behind Detection ===
            -- Enemies behind or beside you are a massive threat
            if dot < -0.3 then
                -- Behind you: extreme threat
                score = score + (150000 * self.Smart3DStrength) * math.clamp(1 - dot, 1, 2)
            elseif dot < 0.2 then
                -- To the side: high threat
                score = score + (80000 * self.Smart3DStrength)
            end

            -- === THREAT VECTOR 2: Enemy Facing You ===
            -- If the enemy is looking directly at you, they're about to shoot
            local eRoot = info.character:FindFirstChild("HumanoidRootPart")
            if eRoot and myRoot then
                local enemyLook = eRoot.CFrame.LookVector
                local toMe = (myRoot.Position - eRoot.Position)
                if toMe.Magnitude > 1 then
                    local aimAtMe = enemyLook:Dot(toMe.Unit)
                    if aimAtMe > 0.7 then
                        -- Directly aiming at us!
                        score = score + 30000 * aimAtMe
                    elseif aimAtMe > 0.3 then
                        score = score + 10000 * aimAtMe
                    end
                end
            end

            -- === THREAT VECTOR 3: Rush Detection ===
            -- Target running toward us = imminent danger
            local targetPred = PredictionData[player]
            local targetVel = targetPred and targetPred.velocity or Vector3.zero
            if dirUnit.Magnitude > 0.1 then
                local rushSpeed = targetVel:Dot(-dirUnit)
                if rushSpeed > 15 then
                    score = score + rushSpeed * 300
                elseif rushSpeed > 5 then
                    score = score + rushSpeed * 100
                end
            end

            -- === THREAT VECTOR 4: Height Advantage ===
            -- Enemies above are harder to deal with
            if dirUnit.Y > 0.5 then
                score = score + 8000
            elseif dirUnit.Y > 0.2 then
                score = score + 3000
            end

            -- === THREAT VECTOR 5: Low HP = Easy Kill ===
            local hpFrac = info.health / math.max(info.maxHealth, 1)
            score = score + (1 - hpFrac) * 15000

            -- === THREAT VECTOR 6: Visibility Bonus ===
            -- Visible targets should be prioritized over occluded ones
            if IsVisibleAdvanced(info.character, info.worldPos) then
                score = score + 25000
            end

            -- === STICKINESS: Prefer current target ===
            if self.LockedPlayer == player then
                score = score + 8000
            end

        else
            -- Classic 2D FOV targeting
            if not info.onScreen or info.depth <= 0 then continue end
            if (info.screenPos - center).Magnitude > self.CurrentFOVRadius then continue end
            score = -self:ScoreTarget(info, center)
        end

        if score > -math.huge then
            table.insert(potentialTargets, {
                player = player, info = info, score = score, is3D = is3D
            })
        end
    end

    table.sort(potentialTargets, function(a, b) return a.score > b.score end)

    local best = nil
    local bestIs3D = false
    for _, targetData in ipairs(potentialTargets) do
        if self.VisCheck then
            if IsVisibleAdvanced(targetData.info.character, targetData.info.worldPos) then
                best = targetData.player
                bestIs3D = targetData.is3D
                break
            end
        else
            best = targetData.player
            bestIs3D = targetData.is3D
            break
        end
    end

    self.LockedPlayer = best
    self._is3DLock = bestIs3D
    self.OccludedTime = 0
    self.LockAge = 0
    self.LastTargetVisible = best ~= nil
end

function Aimbot:Unlock()
    if self.LockedInfo then
        self.LastTargetScreenPos = self.LockedInfo.screenPos
    end
    self.LockedPlayer = nil
    self.LockedInfo = nil
    self.OccludedTime = 0
    self.LockAge = 0
    self.LastTargetVisible = false
    self._is3DLock = false
end

function Aimbot:SmoothAim(targetWorldPos, dt)
    if self.SnapMode then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetWorldPos)
        return
    end

    local camPos = Camera.CFrame.Position

    -- Humanization
    if self.Humanize and self.HumanizeStrength > 0 then
        local t = tick()
        local px = math.noise(t * 2.5, self.HumanizeSeed, 0) * self.HumanizeStrength
        local py = math.noise(self.HumanizeSeed, t * 2.5, 0) * self.HumanizeStrength
        local depth = (targetWorldPos - camPos).Magnitude
        if depth > 1 then
            local fov = math.rad(Camera.FieldOfView)
            local ps = 2 * depth * math.tan(fov / 2) / Camera.ViewportSize.Y
            targetWorldPos = targetWorldPos
                + Camera.CFrame.RightVector * (px * ps)
                + Camera.CFrame.UpVector * (py * ps)
        end
    end

    -- v6.0: Select smoothing parameters based on lock type
    local speed, finalStrength
    if self._is3DLock then
        -- 3D Smart Aim uses its own tracking speed and smoothness
        speed = math.clamp(self.Smart3DSmoothness, 1, 20)
        finalStrength = math.clamp(self.AimStrength * (self.Smart3DTrackingSpeed / 10), 0.1, 1)
    else
        speed = math.clamp(self.Smoothing, 1, 20)
        finalStrength = self.AimStrength
    end

    local springTension = 150 / speed
    local dampening = 2.0 * math.sqrt(springTension) -- Critically damped

    -- v6.0: Customizable ramp-up for auto-switch
    local rampTime = self.RampUpTime
    if self.AutoSwitch and self.LockAge < 0.5 then
        -- Auto-switch uses its own speed parameter
        rampTime = math.clamp(0.3 / self.AutoSwitchSpeed, 0.01, 0.3)
    end

    local ramp = 1
    if self.LockAge < rampTime then
        ramp = math.clamp(self.LockAge / rampTime, 0.05, 1)
        ramp = ramp * ramp -- Quadratic ease-in
    end

    -- Close-Quarters Tracking Boost
    local distToTarget = (camPos - targetWorldPos).Magnitude
    if distToTarget < 50 then
        finalStrength = math.clamp(finalStrength * 1.5, 0.5, 1)
    end

    local alpha = math.clamp(1 - math.exp(-springTension * dt), 0.001, 1) * ramp * finalStrength

    -- v6.0: Auto-switch smoothness factor
    if self.AutoSwitch and self.LockAge < 0.5 then
        local smoothFactor = math.clamp(self.AutoSwitchSmooth / 10, 0.1, 2)
        alpha = alpha * smoothFactor
    end

    -- Sticky vis reduction
    if self.StickyVis and self.OccludedTime > 0 then
        alpha = alpha * self.StickyVisStrength
    end

    local targetCF = CFrame.new(camPos, targetWorldPos)
    local dot = Camera.CFrame.LookVector:Dot(targetCF.LookVector)
    local angle = math.acos(math.clamp(dot, -1, 1))
    local maxAng = math.rad(self.MaxAngularSpeed) * dt
    if angle > 0.001 and angle * alpha > maxAng then
        alpha = maxAng / angle
    end

    Camera.CFrame = Camera.CFrame:Lerp(targetCF, math.clamp(alpha, 0.001, 1))
end

function Aimbot:Update(dt)
    -- Dynamic FOV
    if self.DynamicFOV then
        local scale = Camera.FieldOfView / 70
        local target = self.BaseFOVRadius * scale
        if not self.LockedPlayer then target = target * 1.15 end
        self.CurrentFOVRadius = self.CurrentFOVRadius
            + (target - self.CurrentFOVRadius) * math.min(dt * 8, 1)
    else
        self.CurrentFOVRadius = self.BaseFOVRadius
    end

    -- FOV circle
    if FOVCircle then
        local c = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        FOVCircle.Position = c
        FOVCircle.Radius = self.CurrentFOVRadius
        FOVCircle.Visible = self.Enabled and self.ShowFOV
    end

    if not self.Enabled then return end

    local isAiming = (self.AimKeyMode == "Always On") or self.AimKeyActive
    if not isAiming then return end

    -- Validate lock
    if self.LockedPlayer then
        if not self:IsLockValid(dt) then
            if self.AutoSwitch then
                if self.LockedInfo then
                    self.LastTargetScreenPos = self.LockedInfo.screenPos
                end
                self:Unlock()
                self:AcquireTarget()
                if self.LockedPlayer then
                    -- v6.0: Auto-switch ramp-up based on custom speed
                    self.LockAge = math.clamp(0.3 / self.AutoSwitchSpeed, 0.01, 0.15)
                end
            else
                self:Unlock()
            end
        end
    end

    if not self.LockedPlayer then self:AcquireTarget() end

    -- Aim update
    if self.LockedPlayer then
        self.LockAge = self.LockAge + dt
        local info = self:GetTargetInfo(self.LockedPlayer)
        if info then
            self.LockedInfo = info
            UpdatePrediction(self.LockedPlayer, info.worldPos, dt)
            local aimPos = self.Prediction
                and PredictPosition(self.LockedPlayer, info.worldPos, dt)
                or info.worldPos
            if typeof(aimPos) == "Vector3"
                and aimPos.X == aimPos.X
                and aimPos.Y == aimPos.Y
                and aimPos.Z == aimPos.Z then
                self:SmoothAim(aimPos, dt)
            end
        else
            self:Unlock()
        end
    else
        self.LockedInfo = nil
    end
end

